# ──────────────────────────────────────────────────────────────
# Backend Environment Variables (.env)
# ──────────────────────────────────────────────────────────────

# Environment: "development" | "production"
ENV=development

# ── Firebase ─────────────────────────────────────────────────
# Option A (Local dev): Path to the service account JSON key file
FIREBASE_SERVICE_ACCOUNT_PATH=path/to/serviceAccountKey.json

# Option B (Production host): Full JSON string of the service account key
# Generate with:  cat serviceAccountKey.json | python -c "import sys,json; print(json.dumps(json.load(sys.stdin)))"
# Paste the single-line JSON output as the value (no additional quotes)
# FIREBASE_SERVICE_ACCOUNT_JSON=

FIREBASE_PROJECT_ID=your-firebase-project-id

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API
# Local dev:    http://localhost:3000,http://localhost:3001,http://localhost:3002
# Production:   https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ── FAISS (production only — persistent storage) ─────────
# Leave unset for local dev (defaults to backend/data/faiss/)
# For Hugging Face Spaces Docker, keep defaults unless mounting persistent storage.
# FAISS_DIR=data/faiss
# FAISS_INDEX_PATH=/data/faiss/index.faiss
# FAISS_MAPPING_PATH=/data/faiss/mapping.json

# ── Search / Dashboard Performance ────────────────────────────
MAX_SEARCH_RESULTS=20
DASHBOARD_SAMPLE_LIMIT=500
SEARCH_KEYWORD_SCAN_LIMIT=400
SEARCH_RATE_LIMIT_PER_MINUTE=120
SEARCH_SEMANTIC_MAX_CONCURRENCY=4
SEARCH_SEMANTIC_SLOT_WAIT_SECONDS=0.12
SEARCH_SEMANTIC_FAILURE_WINDOW_SECONDS=60
SEARCH_SEMANTIC_FAILURE_THRESHOLD=8
SEARCH_SEMANTIC_COOLDOWN_SECONDS=45
SEARCH_ENABLE_WARMUP=true
SEARCH_WARMUP_QUERIES=dsa interview questions,system design round,dbms sql joins,os process thread
SEARCH_ENGINE=faiss
TYPESENSE_ENABLED=false
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
# TYPESENSE_API_KEY=xyz
TYPESENSE_COLLECTION=interview_experiences
SEARCH_VECTOR_ALPHA=0.72
SEARCH_RRF_K=60
SEARCH_RRF_VECTOR_WEIGHT=0.7
SEARCH_RRF_LEXICAL_WEIGHT=0.3
SEARCH_INDEX_WORKERS=2
SEARCH_INDEX_QUEUE_MAX=2000
SEARCH_INDEX_WORKER_MODE=embedded
SEARCH_INDEX_QUEUE_BACKEND=memory
SEARCH_INDEX_FIRESTORE_COLLECTION=search_index_tasks
SEARCH_INDEX_MAX_ATTEMPTS=5
SEARCH_INDEX_LEASE_SECONDS=120
SEARCH_INDEX_POLL_INTERVAL_SECONDS=0.6
SEARCH_INDEX_FIRESTORE_CLAIM_BATCH=10
SEARCH_INDEX_DELETE_DONE_TASKS=true
SEARCH_INDEX_FRESHNESS_WARN_SECONDS=900
# SEARCH_REDIS_URL=redis://localhost:6379/0
SEARCH_CACHE_TTL_SECONDS=180
SEARCH_RERANK_ENABLED=true
SEARCH_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
SEARCH_RERANK_TOP_K=30
SEARCH_RERANK_WEIGHT=0.3
SEARCH_LONG_LATENCY_MS=1200
SEARCH_ANALYTICS_TOP_QUERIES=20
DASHBOARD_RATE_LIMIT_PER_MINUTE=90
MUTATION_RATE_LIMIT_PER_MINUTE=80

# ── Role Governance ────────────────────────────────────────────
# Comma-separated emails that should always have placement_cell role.
# Example: PLACEMENT_CELL_EMAILS=pcell@college.edu,placements@college.edu
PLACEMENT_CELL_EMAILS=
